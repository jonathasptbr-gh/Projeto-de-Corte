{
  "name": "Projeto de Corte",
  "short_name": "Corte",
  "description": "Importe CSV, gere o plano de corte por aproveitamento e calcule o orçamento.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#cdd5d0",
  "theme_color": "#2f6f4f",
  "lang": "pt-BR",
  "icons": [
    { "src": "icons/icon.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any" },
    { "src": "icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any maskable" },
    { "src": "icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable" }
  ],
  "launch_handler": { "client_mode": "focus-existing" },
  "share_target": {
    "action": "./share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "file",
          "accept": ["text/csv", "text/comma-separated-values", "application/vnd.ms-excel", "application/csv", "text/plain", "application/octet-stream", ".csv"]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "text/csv": [".csv"],
        "application/vnd.ms-excel": [".csv"],
        "text/comma-separated-values": [".csv"]
      }
    }
  ]
}
